[sub_resource type="Shader" id="Shader_53or2"]
code = "shader_type canvas_item;

uniform vec3 bg_color : source_color = vec3(0.4);
uniform vec3 fg_color : source_color = vec3(1.0, 0.835, 0.29);
uniform float opacity : hint_range(0.0, 1.0, 0.01) = 0.0;
uniform bool solid = false;

float smax(float d1, float d2, float k) {
	float h = clamp(0.5 - 0.5*(d2 - d1)/k, 0.0, 1.0);
	return mix(d2, d1, h) + k*h*(1.0 - h); 
}

void fragment() {
	const float radius = 0.03;
	vec2 p = (UV - 0.5) * vec2(1.0, 0.5);
	vec3 result = bg_color;

	float dist = length(max(abs(p) - vec2(0.5, 0.0), vec2(0.0)));
	dist -= smoothstep(0.0, 1.0, smax((abs(UV.x - 0.5) - 0.3) * 3.2, 0.0, 0.8)) * 0.1;
	dist = smax(dist, 0.2 - distance(vec2(abs(p.x), p.y), vec2(0.63, 0.0)), 0.035);
	float mask = smoothstep(radius + fwidth(dist), radius - fwidth(dist), dist);

	float offset = (sin(TIME * PI) + 1.0) * 0.5;
	float pulse = fract((UV.x * 0.8 - (TIME- 0.7) * 0.7) - 0.5);
	pulse = smoothstep(0.3, 0.0, abs((UV.x * 2.0 - 1.0) * 0.3 - offset + 0.5)) * 0.8;

	if (solid)
		pulse = 1.0;

	result = mix(result, fg_color, pulse * opacity);
	COLOR = vec4(result, mask);
}
"

